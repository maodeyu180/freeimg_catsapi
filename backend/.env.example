# ── LinuxDo OAuth2 ──
# 新注册的 freeimage_linuxdo 应用凭证
LINUXDO_CLIENT_ID=
LINUXDO_CLIENT_SECRET=
LINUXDO_REDIRECT_URI=http://localhost:5174/auth/callback
LINUXDO_AUTHORIZE_URL=https://connect.linux.do/oauth2/authorize
LINUXDO_TOKEN_URL=https://connect.linux.do/oauth2/token
LINUXDO_USER_URL=https://connect.linux.do/api/user

# ── JWT ──
JWT_SECRET=change-me-to-random-string
JWT_EXPIRE_DAYS=7

# ── 上游 catsapi ──
CATSAPI_URL=http://catsapi.com
CATSAPI_KEY=your-api-key

# ── App ──
APP_NAME=喵的公益生图
DEBUG=false
CORS_ORIGINS=["http://localhost:5174","http://127.0.0.1:5174","https://catsapi.com","https://freeimg.catsapi.com"]
DATABASE_URL=sqlite+aiosqlite:///./freeimage.db

# ── 访问控制 ──
# 允许登录的最低 LinuxDo 信任等级
MIN_TRUST_LEVEL=1
# 管理员 LinuxDo 数字 ID 白名单，逗号分隔
ADMIN_LINUXDO_IDS=

# ── 全局并发 & 配额 ──
# 同时运行的任务数上限（对应你在 catsapi.com 为内部账号设置的 max_concurrent_tasks）
MAX_CONCURRENT_TASKS=4
# 每用户每日配额
DAILY_IMAGE_LIMIT=20
DAILY_VIDEO_LIMIT=3
# 配额重置时区（自然日计算）
QUOTA_TIMEZONE=Asia/Shanghai

# ── Worker ──
WORKER_POLL_INTERVAL_SECONDS=3
TASK_TIMEOUT_MINUTES=15
